# =============================================================
#  .env.example  —  Plantilla de variables para docker-compose
# =============================================================
#  Copia este archivo como .env y ajusta los valores:
#    cp .env.example .env
#
#  ¡CAMBIA todos los valores marcados con CAMBIAR antes de usar!
# =============================================================

# Contraseña root de MariaDB (solo para el contenedor)
DB_ROOT_PASSWORD=CAMBIAR_EN_SERVIDOR

# Base de datos de la aplicación
DB_NAME=tecnocell_web

# Usuario de la aplicación (NO usar root en producción)
DB_USER=tecnocell_user
DB_PASSWORD=CAMBIAR_EN_SERVIDOR
